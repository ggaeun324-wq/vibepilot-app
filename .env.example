# GitHub MCP integration
# Prefer GITHUB_MCP_TOKEN for GitHub MCP so it is not confused with CI-provided GITHUB_TOKEN.
# Use a fine-grained PAT scoped to the repositories you want VibePilot to read.
GITHUB_MCP_TOKEN=
GITHUB_MCP_ENABLED=true
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/

# Copilot SDK runtime
# Usually left empty because the app auto-detects node_modules/.bin/copilot.
COPILOT_CLI_PATH=
COPILOT_MODEL=

# Azure OpenAI / Azure AI Foundry BYOM (optional)
# Set MODEL_PROVIDER=azure only when using Azure BYOM through the Copilot SDK provider.
MODEL_PROVIDER=
AZURE_OPENAI_ENDPOINT=
MODEL_NAME=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
COPILOT_MODEL_ID=
AZURE_CLIENT_ID=

# Database-backed auth and project persistence
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vibepilot?schema=public

# Legacy Azure OpenAI REST fallback variables, used by older flows if enabled.
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_KEY=
